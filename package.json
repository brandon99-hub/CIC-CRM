{
  "name": "marketing-pipeline-dashboard",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npx tsx --env-file=.env server/index.ts\" \"npx tsx --env-file=.env server/worker.ts\"",
    "build": "vite build && esbuild server/index.ts --bundle --platform=node --outfile=dist/index.js --format=esm --packages=external && esbuild server/worker.ts --bundle --platform=node --outfile=dist/worker.js --format=esm --packages=external",
    "start": "concurrently \"NODE_ENV=production node dist/index.js\" \"NODE_ENV=production node dist/worker.js\"",
    "db:push": "drizzle-kit push --config=drizzle.config.ts"
  },
